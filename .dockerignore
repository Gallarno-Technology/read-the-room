# Secrets and runtime credentials — must never be baked into image layers
.env
token_cache/

# Runtime state and data — container-managed, not source
state.json
data/
lyrics_cache.db

# Per-user registry and state — lives on Fly volume at /data, symlinked in
# by web_ui/entrypoint.sh. Local docker-compose bind-mounts these instead.
users.json
users/

# Python bytecode
__pycache__/
*.pyc
*.pyo

# Version control and dev tooling — not needed at runtime
.git/
.claude/
.planning/

# Test suite — not needed at runtime
tests/
