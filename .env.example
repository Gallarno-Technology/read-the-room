# Spotify OAuth credentials
# Register your app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
# Must be registered in Spotify Dashboard -> Your App -> Redirect URIs
# Spotify Dashboard requires HTTPS for 127.0.0.1 — use https here too.
# The app doesn't start a server; after approval the browser fails to load
# the redirect page (expected), copy the full URL from the address bar and paste it back.
SPOTIFY_REDIRECT_URI=https://127.0.0.1:8080

# Token cache path (inside container: /app/token_cache/.cache)
SPOTIFY_CACHE_PATH=/app/token_cache/.cache

# Polling configuration
POLL_INTERVAL_SECONDS=1
HEARTBEAT_INTERVAL_SECONDS=300

# State file path (inside container: /app/state.json)
STATE_PATH=/app/state.json

# Content filtering (Phase 2)
# Minimum profanity severity to trigger skip (1=mild, 2=moderate, 3=severe)
PROFANITY_MIN_SEVERITY=2

# SQLite lyrics cache path (inside container)
LYRICS_DB_PATH=/app/lyrics_cache.db

# Web UI dashboard port (served by FastAPI/uvicorn — Phase 3)
WEB_UI_PORT=8888
