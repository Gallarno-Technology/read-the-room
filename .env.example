# Domain & networking — set these for VPS deployment
# APP_DOMAIN: the domain Caddy serves (and provisions a Let's Encrypt cert for)
#   VPS: set to your public domain, e.g. APP_DOMAIN=yourdomain.com
#   Local home server: set to your LAN IP, e.g. APP_DOMAIN=192.168.1.220
# APP_DOMAIN=yourdomain.com

# WEB_UI_UPSTREAM: Caddy reverse proxy target
#   VPS (bridge network): web_ui:8888  (Caddy reaches web_ui via Docker service name)
#   Local home server (host network): localhost:8888  (default — leave unset)
# WEB_UI_UPSTREAM=web_ui:8888

# NETWORK_MODE: Docker network mode for all services
#   VPS deployment: bridge  (Sonos not available on VPS; bridge is correct for Caddy service routing)
#   Local home server: host  (required for Sonos UPnP/multicast — leave unset to use default)
# NETWORK_MODE=bridge

# Spotify OAuth credentials
# Register your app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here
# Must be registered in Spotify Dashboard -> Your App -> Redirect URIs
# Set to https://{APP_DOMAIN}/auth/callback — replace {APP_DOMAIN} with your actual domain.
# VPS example:          SPOTIFY_REDIRECT_URI=https://yourdomain.com/auth/callback
# Local home server:    SPOTIFY_REDIRECT_URI=https://192.168.1.220/auth/callback
SPOTIFY_REDIRECT_URI=https://yourdomain.com/auth/callback

# Token cache path (inside container: /app/token_cache/.cache)
SPOTIFY_CACHE_PATH=/app/token_cache/.cache

# Polling configuration
POLL_INTERVAL_SECONDS=1
HEARTBEAT_INTERVAL_SECONDS=300

# State file path (inside container: /app/state.json)
STATE_PATH=/app/state.json

# Content filtering (Phase 2)
# Minimum profanity severity to trigger skip (1=mild, 2=moderate, 3=severe)
PROFANITY_MIN_SEVERITY=2

# SQLite lyrics cache path (inside container)
LYRICS_DB_PATH=/app/lyrics_cache.db

# Web UI dashboard port (served by FastAPI/uvicorn — Phase 3)
WEB_UI_PORT=8888

# Sonos speaker IP addresses — optional escape hatch for networks where SSDP/multicast is
# blocked (firewalls, Proxmox LXC without bridge multicast forwarding). SSDP is used
# automatically when this is unset. Format: "Room Name=IP,Other Room=IP"
# (use the exact name Spotify reports for the device)
# Find IPs in the Sonos app: Settings -> System -> [Room] -> About [Room]
# SONOS_SPEAKER_IPS=Dining Room=192.168.1.50,Living Room=192.168.1.51

# Docker user/group IDs — required so bind-mount files are owned by your user, not root.
# On Linux/macOS: export UID=$(id -u) && export GID=$(id -g) before running docker compose.
# Matches user: "${UID}:${GID}" in docker-compose.yml.
UID=1000
GID=1000

# Events log path — shared JSONL file written by daemon, read by web_ui.
# Both services read this env var; defaults to data/events.jsonl when unset.
# Both Docker volume mounts must make this path accessible inside each container.
EVENTS_PATH=data/events.jsonl
